rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null
        && request.auth.uid == 'mCSgNMVEphVIIf4HX0bkcKq2ZKv2';
    }

    function isMassimo() {
      return request.auth != null
        && request.auth.uid == '0u41pvwSTAaryAGWAG8gwuxrZ293';
    }

    function isSuperUser() {
      return isAdmin() || isMassimo();
    }

    function staffRef(uid) {
      return /databases/(default)/documents/staff/$(uid);
    }

    // Qualsiasi membro dello staff autenticato
    function isStaff() {
      return request.auth != null
        && firestore.exists(staffRef(request.auth.uid));
    }

    // Qualunque coordinatrice (per Documenti Generali / Segreteria)
    function isAnyCoordinatrice() {
      return request.auth != null
        && firestore.exists(staffRef(request.auth.uid))
        && firestore.get(staffRef(request.auth.uid)).data.ruolo.matches('.*Coordinatrice.*');
    }

    // Coordinatrice: può accedere se comunitaId è nel suo array (o uguale alla stringa)
    function isCoordinatriceForComunita(comunitaId) {
      let staffData = firestore.get(staffRef(request.auth.uid)).data;
      return request.auth != null
        && firestore.exists(staffRef(request.auth.uid))
        && staffData.ruolo.matches('.*Coordinatrice.*')
        && (
          // Array (nuovo formato): usa operatore "in"
          (staffData.comunitaId is list && comunitaId in staffData.comunitaId)
          // Stringa (vecchio formato, backward compat)
          || staffData.comunitaId == comunitaId
        );
    }

    // ── Documenti Generali / Segreteria ──────────────────────────
    // Accessibili a superuser e a qualsiasi membro dello staff autenticato
    match /documenti/documenti-generali/{file} {
      allow read, write: if isSuperUser() || isStaff();
    }

    // ── Area Documenti per comunità ───────────────────────────────
    // Struttura: documenti/{comunitaId}/{uid}/{area}/{...sottocartelle}/{file}
    match /documenti/{comunitaId}/{allPaths=**} {
      allow read, write: if isSuperUser() || isCoordinatriceForComunita(comunitaId);
    }

    // ── Tutto il resto (foto profilo, audio, media) ───────────────
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
