rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // UID amministratore con poteri assoluti
    function isAdmin() {
      return request.auth != null && request.auth.uid == 'mCSgNMVEphVIIf4HX0bkcKq2ZKv2';
    }

    // Utente loggato ha un campo booleano true nel proprio documento utenti
    function userHas(field) {
      return request.auth != null &&
             exists(/databases/$(database)/documents/utenti/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/utenti/$(request.auth.uid)).data[field] == true;
    }

    // Admin può leggere e scrivere tutto
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // Comunità: sola lettura pubblica
    match /comunita/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Utenti: lettura pubblica, scrittura solo sul proprio documento
    match /utenti/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Staff: lettura pubblica, scrittura solo admin
    match /staff/{uid} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Diario
    match /diario/{id} {
      allow read: if true;
      allow create: if request.auth != null &&
                       request.resource.data.uidRagazzo == request.auth.uid;
      allow delete: if request.auth != null && (
                       resource.data.uidRagazzo == request.auth.uid ||
                       userHas('admin')
                    );
      allow update: if request.auth != null && (
                       resource.data.uidRagazzo == request.auth.uid ||
                       userHas('admin')
                    );

      // Reazioni: ogni utente loggato gestisce la propria
      match /reazioni/{userId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Messaggi in bottiglia
    match /messaggiBottiglia/{id} {
      allow read: if true;
      allow create: if request.auth != null &&
                       (userHas('autorizzato') || isAdmin()) &&
                       request.resource.data.uidMittente == request.auth.uid &&
                       request.resource.data.uidMittente != request.resource.data.uidDestinatario;
      allow delete: if request.auth != null && (
                       resource.data.uidDestinatario == request.auth.uid ||
                       userHas('admin') ||
                       isAdmin()
                    );
      allow update: if false;
    }

  }
}
