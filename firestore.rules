rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.uid == 'mCSgNMVEphVIIf4HX0bkcKq2ZKv2';
    }

    function userHas(field) {
      return request.auth != null &&
             exists(/databases/$(database)/documents/utenti/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/utenti/$(request.auth.uid)).data[field] == true;
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }

    match /comunita/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /utenti/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    match /staff/{uid} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /diario/{id} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.uidRagazzo == request.auth.uid;
      allow delete: if request.auth != null && (resource.data.uidRagazzo == request.auth.uid || userHas('admin'));
      allow update: if request.auth != null && (resource.data.uidRagazzo == request.auth.uid || userHas('admin'));

      match /reazioni/{userId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null && request.auth.uid == userId;
      }

      match /commenti/{commentoId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (
          resource.data.uidAutore == request.auth.uid ||
          userHas('admin') ||
          get(/databases/$(database)/documents/diario/$(id)).data.uidRagazzo == request.auth.uid
        );
        allow update: if false;
      }
    }

    match /messaggiBottiglia/{id} {
      allow read: if true;
      allow create: if request.auth != null &&
                       (userHas('autorizzato') || isAdmin()) &&
                       request.resource.data.uidMittente == request.auth.uid &&
                       request.resource.data.uidMittente != request.resource.data.uidDestinatario;
      allow delete: if request.auth != null && (resource.data.uidDestinatario == request.auth.uid || userHas('admin') || isAdmin());
      allow update: if request.auth != null && (resource.data.uidDestinatario == request.auth.uid || isAdmin());

      match /reazioni/{userId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null && request.auth.uid == userId;
      }

      match /commenti/{commentoId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (
          resource.data.uidAutore == request.auth.uid ||
          userHas('admin') ||
          get(/databases/$(database)/documents/messaggiBottiglia/$(id)).data.uidDestinatario == request.auth.uid
        );
        allow update: if false;
      }
    }

  }
}
