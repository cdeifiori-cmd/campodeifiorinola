rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.uid == 'mCSgNMVEphVIIf4HX0bkcKq2ZKv2';
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function isLoggedIn() {
      return request.auth != null;
    }

    // ── Utenti ──────────────────────────────────────────────
    match /utenti/{uid} {
      allow read: if true;
      allow create: if isOwner(uid) || isAdmin();
      allow update: if isOwner(uid) || isAdmin()
                    // Qualsiasi utente loggato può aggiornare solo il campo reazioniPresento
                    || (isLoggedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reazioniPresento']));
      allow delete: if isAdmin();

      // Reazioni su "Mi Presento": ogni utente gestisce solo la propria
      match /reazioniPresento/{reazId} {
        allow read: if true;
        allow write: if isLoggedIn() && request.auth.uid == reazId;
      }
    }

    // ── Staff ────────────────────────────────────────────────
    match /staff/{uid} {
      allow read: if true;
      allow update: if isOwner(uid) || isAdmin();
      allow create, delete: if isAdmin();
    }

    // ── Amici ────────────────────────────────────────────────
    match /amici/{uid} {
      allow read: if true;
      allow update: if isOwner(uid) || isAdmin();
      allow create, delete: if isAdmin();
    }

    // ── Comunità ─────────────────────────────────────────────
    match /comunita/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Diario ───────────────────────────────────────────────
    match /diario/{postId} {
      allow read: if true;
      // Solo il proprietario del profilo può creare post nel proprio diario
      allow create: if isLoggedIn()
                    && request.auth.uid == request.resource.data.uidRagazzo;
      // Il proprietario/admin possono aggiornare tutto il documento;
      // qualsiasi utente loggato può aggiornare SOLO il campo reazioni (contatori).
      allow update: if isLoggedIn()
                    && (
                      request.auth.uid == resource.data.uidRagazzo
                      || isAdmin()
                      || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reazioni'])
                    );
      allow delete: if isLoggedIn()
                    && (request.auth.uid == resource.data.uidRagazzo || isAdmin());

      // Commenti al diario: scrivibili solo dai loggati
      match /commenti/{commentId} {
        allow read: if true;
        allow create: if isLoggedIn();
        allow delete: if isLoggedIn()
                      && (request.auth.uid == resource.data.uidAutore || isAdmin());
        allow update: if false;
      }

      // Reazioni ai post: ogni utente gestisce solo la propria
      match /reazioni/{userId} {
        allow read: if true;
        allow write: if isLoggedIn() && request.auth.uid == userId;
      }
    }

    // ── Piazzetta ────────────────────────────────────────────
    match /piazzetta_posts/{postId} {
      allow read: if true;
      allow create: if isLoggedIn();
      allow update: if isLoggedIn() && (
        request.auth.uid == resource.data.authorId
        || isAdmin()
        || request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['reactions', 'commentsCount'])
      );
      allow delete: if isLoggedIn() &&
        (request.auth.uid == resource.data.authorId || isAdmin());

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isLoggedIn();
        allow update: if isLoggedIn() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']);
        allow delete: if isLoggedIn() &&
          (request.auth.uid == resource.data.authorId || isAdmin());
      }

      match /user_reactions/{userId} {
        allow read: if isLoggedIn();
        allow write: if isLoggedIn() && request.auth.uid == userId;
      }
    }

    // ── Notifiche (contatore non lette per utente) ──────────
    match /notifiche/{uid} {
      allow read:  if isOwner(uid);
      allow write: if isOwner(uid);
    }

    // ===== ROBINSON =====

    // La Spiaggia - post condivisi
    match /robinson_spiaggia/{postId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow update: if isLoggedIn() && (
        request.auth.uid == resource.data.authorId
        || isAdmin()
        || request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['reactions', 'commentsCount'])
      );
      allow delete: if isLoggedIn() &&
        (request.auth.uid == resource.data.authorId || isAdmin());

      match /comments/{commentId} {
        allow read: if isLoggedIn();
        allow create: if isLoggedIn();
        allow update: if isLoggedIn() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']);
        allow delete: if isLoggedIn() &&
          (request.auth.uid == resource.data.authorId || isAdmin());
      }

      match /user_reactions/{userId} {
        allow read: if isLoggedIn();
        allow write: if isLoggedIn() && request.auth.uid == userId;
      }
    }

    // Diario della ciurma - racconto quotidiano dell'équipe educativa
    match /robinson_diario_ciurma/{postId} {
      allow read: if isLoggedIn();
      // Solo chi è nella ciurma (o l'admin) può scrivere una pagina di diario
      allow create: if isLoggedIn() &&
        (isAdmin() || exists(/databases/$(database)/documents/robinson_ciurma/$(request.auth.uid)));
      allow update: if isLoggedIn() && (
        request.auth.uid == resource.data.authorId
        || isAdmin()
        || request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['reactions', 'commentsCount'])
      );
      allow delete: if isLoggedIn() &&
        (request.auth.uid == resource.data.authorId || isAdmin());

      match /comments/{commentId} {
        allow read: if isLoggedIn();
        allow create: if isLoggedIn();
        allow update: if isLoggedIn() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']);
        allow delete: if isLoggedIn() &&
          (request.auth.uid == resource.data.authorId || isAdmin());
      }

      match /user_reactions/{userId} {
        allow read: if isLoggedIn();
        allow write: if isLoggedIn() && request.auth.uid == userId;
      }
    }

    // I Naufraghi - profili
    match /robinson_naufraghi/{uid} {
      allow read: if isLoggedIn();
      allow write: if isLoggedIn() && (isOwner(uid) || isAdmin());

      match /profilo/{docId} {
        allow read: if isLoggedIn();
        allow write: if isLoggedIn() && (isOwner(uid) || isAdmin());
      }

      match /carta_identita/{docId} {
        allow read: if isLoggedIn();
        allow create: if isOwner(uid) || isAdmin();
        allow update: if isAdmin() ||
          (isOwner(uid) && resource.data.get('bloccata', false) == false);
        allow delete: if isAdmin();
      }

      match /notte_partenza/{docId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.auth.uid == uid;
        allow update: if request.auth != null &&
          get(/databases/$(database)/documents/utenti/$(request.auth.uid)).data.ruolo == 'admin';
      }
    }

    // Diari personali naufraghi
    match /robinson_diari/{uid}/{document=**} {
      allow read: if request.auth != null;
      // write solo tramite regole specifiche /posts/{postId}
    }

    match /robinson_diari/{uid}/posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && (
        isAdmin() ||
        (request.auth.uid == uid && resource.data.get('bloccata', false) == false) ||
        // Tesori: aggiornamento solo del campo media sempre consentito al proprietario
        (request.auth.uid == uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['media', 'timestamp']))
      );
      allow delete: if isAdmin();

      match /reactions/{userId} {
        allow read: if isLoggedIn();
        allow write: if isLoggedIn() && request.auth.uid == userId;
      }

      match /commenti/{commentId} {
        allow read: if isLoggedIn();
        allow create: if isLoggedIn();
        allow delete: if isLoggedIn() &&
          (request.auth.uid == resource.data.authorId || isOwner(uid) || isAdmin());
        allow update: if false;
      }
    }

    // La Ciurma - operatori Robinson
    match /robinson_ciurma/{uid} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // ── Robinson: Dicono di me ──────────────────────────────────────────────
    match /robinson_dicono/{uid}/posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid != uid;
      allow delete: if request.auth != null &&
        (request.auth.uid == resource.data.autorId ||
         get(/databases/$(database)/documents/utenti/$(request.auth.uid)).data.ruolo == 'admin');
    }
    match /robinson_dicono/{uid}/posts/{postId}/reactions/{rId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /robinson_dicono/{uid}/posts/{postId}/commenti/{cId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Isola dei Sentimenti ─────────────────────────────────
    match /robinson_isola/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    match /robinson_isola/{uid}/notti/{data} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ── PIN Login naufraghi ──────────────────────────────────────
    match /robinson_pin/{uid} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Lookup pubblico (necessario per il login senza auth)
    match /robinson_pin_lookup/{pin} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /robinson_isola_presenze/{docId} {
      allow read: if isLoggedIn();
      allow write: if isLoggedIn();
    }

    // ── Archivio notturno isola ──────────────────────────────
    match /robinson_isola_archivio/{data} {
      allow read: if isAdmin();
      allow write: if request.auth != null;
    }

    // ── Villaggio ────────────────────────────────────────────
    match /robinson_villaggio/{casaId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ── Villaggio: valutazioni giornaliere pulizia/organizzazione (admin-only) ──
    match /robinson_villaggio_valutazioni/{valutazioneId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ── Punteggi Robinson ────────────────────────────────────
    match /robinson_punteggi/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Bottiglie Robinson (messaggi tra naufraghi) ──────────
    match /robinson_bottiglie/{uid}/messaggi/{msgId} {
      allow read: if request.auth != null &&
        (request.auth.uid == uid || isAdmin());
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
        (request.auth.uid == uid || isAdmin());
      allow delete: if request.auth != null &&
        (request.auth.uid == uid || isAdmin());
    }

    // ── Inviati Robinson (copia messaggi inviati) ────────────
    match /robinson_inviati/{uid}/messaggi/{msgId} {
      allow read: if request.auth != null &&
        (request.auth.uid == uid || isAdmin());
      allow create: if request.auth != null && request.auth.uid == uid;
      allow delete: if isAdmin();
    }

    // ── Richieste di modifica carta d'identità ───────────────
    match /robinson_richieste/{uid} {
      allow read: if request.auth != null &&
        (request.auth.uid == uid || isAdmin());
      allow write: if request.auth != null &&
        (request.auth.uid == uid || isAdmin());
    }

    // ── Notte prima dello sbarco (Robinson) ─────────────────
    match /notte_sbarco/{uid} {
      allow read: if isLoggedIn();
      allow write: if isOwner(uid) || isAdmin();
    }

    // ── Messaggi in Bottiglia ────────────────────────────────
    match /messaggiBottiglia/{bottId} {
      allow read: if true;  // lettura pubblica (sola lettura per non loggati)
      allow create: if isLoggedIn()
                    && request.auth.uid == request.resource.data.uidMittente
                    && request.auth.uid != request.resource.data.uidDestinatario;
      allow update: if isLoggedIn()
                    && (
                      request.auth.uid == resource.data.uidDestinatario
                      || isAdmin()
                      || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reazioni'])
                    );
      allow delete: if isLoggedIn()
                    && (request.auth.uid == resource.data.uidDestinatario
                        || request.auth.uid == resource.data.uidMittente
                        || isAdmin());

      // Commenti alle bottiglie
      match /commenti/{commentId} {
        allow read: if true;  // leggibili anche da non loggati
        allow create: if isLoggedIn();
        allow delete: if isLoggedIn()
                      && (request.auth.uid == resource.data.uidAutore || isAdmin());
        allow update: if false;
      }

      // Reazioni alle bottiglie
      match /reazioni/{userId} {
        allow read: if true;  // leggibili anche da non loggati
        allow write: if isLoggedIn() && request.auth.uid == userId;
      }
    }

    // ── Attività (hub ATTIVITÀ + Il Consiglio dell'Isola) ────────────────
    function isEducatore() {
      return isAdmin(); // estendibile: aggiungere altri uid in questa funzione
    }
    function rilevazioneAperta(attId, rilId) {
      return get(/databases/$(database)/documents/attivita/$(attId)/rilevazioni/$(rilId)).data.stato == 'aperta';
    }

    match /attivita/{attId} {
      allow read: if isLoggedIn();
      allow write: if isEducatore();

      match /rilevazioni/{rilId} {
        allow read: if isLoggedIn();              // meta + sintesiPubblica (no PII)
        allow write: if isEducatore();

        match /risposte/{userId} {
          allow read: if isEducatore() || (isLoggedIn() && request.auth.uid == userId);
          allow create, update: if isLoggedIn() && request.auth.uid == userId
            && rilevazioneAperta(attId, rilId);
          allow delete: if isEducatore();
        }
      }
    }

    // ── Bussola del gruppo — questionario "Migliori/Peggiori/Chi può migliorare" ──────
    // Strumento diagnostico admin-only: nessun naufrago vede MAI le risposte altrui né gli
    // aggregati (list riservato all'admin: impedisce l'enumerazione dell'intera collezione).
    // get invece è aperto anche al proprietario perché bussola-gruppo.html lo usa per il
    // resume della propria compilazione (rilegge SOLO il proprio doc, mai quello di altri).
    // Update consentito al proprietario finché il documento non è bloccato dall'admin (stesso
    // pattern di robinson_naufraghi/carta_identita); reset/delete solo admin.
    match /robinson_questionario_campo/{uid} {
      allow get: if isAdmin() || isOwner(uid);
      allow list: if isAdmin();
      allow create: if isOwner(uid);
      allow update: if isAdmin() ||
        (isOwner(uid) && resource.data.get('bloccata', false) == false);
      allow delete: if isAdmin();
    }

    // ── Gestione: Magazzino & Lista spesa (NON deployare senza ok esplicito di Giacomo) ──
    // Accesso solo admin o persone abilitate dall'admin (PIN Robinson risolto a UID
    // stabile, vedi robinson/js/robinson-magazzino.js:puoAccedereGestione).
    function puoAccedereGestione() {
      return isAdmin() ||
        (isLoggedIn() && exists(/databases/$(database)/documents/magazzino_autorizzati/$(request.auth.uid)));
    }

    match /magazzino_categorie/{doc} { allow read, write: if puoAccedereGestione(); }
    match /magazzino_prodotti/{doc}  { allow read, write: if puoAccedereGestione(); }
    match /liste_spesa/{id} {
      allow read, write: if puoAccedereGestione();
      match /voci/{voceId} { allow read, write: if puoAccedereGestione(); }
    }
    // Regola separata per la collection-group query su "voci" usata dallo storico
    // (gestione-storico.html: collectionGroup(db,'voci')) — la match annidata sopra
    // copre solo le letture dirette sotto liste_spesa/{id}/voci, non la collection group.
    match /{path=**}/voci/{voceId} { allow read: if puoAccedereGestione(); }
    match /magazzino_autorizzati/{uid} {
      allow read: if puoAccedereGestione();
      allow write: if isAdmin();
    }
  }
}
