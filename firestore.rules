rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: controlla se l'utente loggato ha un campo vero
    function userHas(field) {
      return request.auth != null &&
             exists(/databases/$(database)/documents/utenti/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/utenti/$(request.auth.uid)).data[field] == true;
    }

    // Comunità: sola lettura pubblica
    match /comunita/{id} {
      allow read: if true;
      allow write: if false;
    }

    // Utenti: lettura pubblica, scrittura solo sul proprio documento
    match /utenti/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Diario
    match /diario/{id} {
      allow read: if true;
      allow create: if request.auth != null &&
                       request.resource.data.uidRagazzo == request.auth.uid;
      allow delete: if request.auth != null && (
                       resource.data.uidRagazzo == request.auth.uid ||
                       userHas('admin')
                    );
      allow update: if request.auth != null &&
                       resource.data.uidRagazzo == request.auth.uid;

      // Sotto-collezione reazioni: ogni utente loggato gestisce la propria
      match /reazioni/{userId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Messaggi in bottiglia
    match /messaggiBottiglia/{id} {
      allow read: if true;
      allow create: if request.auth != null &&
                       userHas('autorizzato') &&
                       request.resource.data.uidMittente == request.auth.uid &&
                       request.resource.data.uidMittente != request.resource.data.uidDestinatario;
      allow delete: if request.auth != null && (
                       resource.data.uidDestinatario == request.auth.uid ||
                       userHas('admin')
                    );
      allow update: if false;
    }

  }
}
